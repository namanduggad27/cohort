# ============================================================
# AI Clinical Voice Scribe – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ----------------------------
# Anthropic (Claude Haiku + Sonnet)
# ----------------------------
ANTHROPIC_API_KEY=

# ----------------------------
# Sarvam STT (Primary - Indic languages / Hinglish)
# https://dashboard.sarvam.ai
# ----------------------------
SARVAM_API_KEY=
SARVAM_API_URL=https://api.sarvam.ai/speech-to-text-translate

# ----------------------------
# OpenAI (Embeddings only - text-embedding-3-small)
# ----------------------------
OPENAI_API_KEY=

# ----------------------------
# Pinecone (Vector DB)
# https://app.pinecone.io
# ----------------------------
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=clinical-scribe

# ----------------------------
# Backend Server
# ----------------------------
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# Rate limiting (requests per 15 minutes per IP)
API_RATE_LIMIT=100

# Request size limit
REQUEST_SIZE_LIMIT=50mb

# ----------------------------
# Frontend (Vite - prefix VITE_)
# ----------------------------
VITE_API_BASE_URL=http://localhost:3001

# ----------------------------
# Logging (Winston)
# ----------------------------
LOG_LEVEL=info

# ----------------------------
# Billing Safety Caps (informational — set in dashboard)
# Anthropic: set monthly spend cap at dashboard.anthropic.com
# OpenAI: set monthly spend cap at platform.openai.com
# ----------------------------
# Target: ~₹5.25 per consult
# ₹2.50 Sarvam + ₹0.20 Haiku + ₹2.50 Sonnet + ₹0.05 embeddings
